@startuml
skinparam defaultTextAlignment center
skinparam activityFontSize 18
skinparam activityDiamondFontSize 16
skinparam activityArrowFontSize 16
skinparam activityBackgroundColor #bce8f5ff
skinparam activityDiamondBackgroundColor #bce8f5ff
skinparam activityStartColor #4CAF50
skinparam activityStopColor #F44336

|Admin|
start
:Chọn chức năng\nquản lý nhà hàng;
|Hệ thống|
:Hiển thị giao diện\nquản lý nhà hàng;
|Admin|
:Chọn nhà hàng cần sửa;
|Hệ thống|
:Hiển thị form\nthông tin nhà hàng;
|Admin|
:Chọn sửa nhà hàng;
|Hệ thống|
:Hiển thị form sửa\nthông tin nhà hàng;
|Admin|
:Chỉnh sửa thông tin nhà hàng;
:Gửi thông tin đã sửa;
|Hệ thống|
:Nhận thông tin\nđã sửa;
if (Kiểm tra\nthông tin) then (Lỗi)
    :Thông báo lỗi,\nyêu cầu nhập lại;
    :Hiển thị\nthông báo lỗi;
    stop
else (Hợp lệ)
    :Cập nhật thông\ntin nhà hàng;
    :Trả về kết\nquả thành công;
    :Cập nhật giao diện;
    stop
endif
@enduml
