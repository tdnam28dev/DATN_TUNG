@startuml
skinparam defaultTextAlignment center
skinparam activityFontSize 18
skinparam activityDiamondFontSize 16
skinparam activityArrowFontSize 16
skinparam activityBackgroundColor #bce8f5ff
skinparam activityDiamondBackgroundColor #bce8f5ff
skinparam activityStartColor #4CAF50
skinparam activityStopColor #F44336

|Staff|
start
:Nhập số điện thoại\nkhách hàng;
|Hệ thống|
:Kiểm tra khách hàng\ntheo số điện thoại;
if (Đã tồn tại\nkhách hàng?) then (Có)
    :Hiển thị thông tin khách hàng;
    |Staff|
    :Chỉnh sửa\nthông tin (nếu cần);
    :Gửi thông tin cập nhật;
    |Hệ thống|
    :Cập nhật thông tin khách hàng;
    :Trả về kết quả thành công;
    stop
else (Không)
    :Hiển thị form nhập thông tin khách hàng mới;
    |Staff|
    :Nhập thông tin khách hàng;
    :Gửi thông tin khách hàng;
    |Hệ thống|
    :Lưu khách hàng mới;
    :Trả về kết quả thành công;
    stop
endif
@enduml
